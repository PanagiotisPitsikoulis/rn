{
  "name": "cn6035-theatre-booking",
  "version": "1.0.0",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/core/*",
    "packages/headless/*",
    "packages/native/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:server": "bun --filter @cn6035/server dev",
    "dev:mobile": "bun --filter @cn6035/mobile dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "seed": "bun --filter @cn6035/server seed",
    "db:schema": "bun --filter @cn6035/server db:schema",
    "db:seed": "bun --filter @cn6035/server db:seed"
  },
  "devDependencies": {
    "@types/react": "~19.2.15",
    "typescript": "~6.0.3",
    "turbo": "^2.5.4"
  }
}
